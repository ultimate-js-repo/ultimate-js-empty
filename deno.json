{
  "imports": {
    "@ultimate-js/core": "jsr:@ultimate-js/core",
    "@ultimate-js/protocol": "jsr:@ultimate-js/protocol",
    "@ultimate-js/rpc-client": "jsr:@ultimate-js/rpc-client",
    "@ultimate-js/rpc-server": "jsr:@ultimate-js/rpc-server",
    "@ultimate-js/hono": "jsr:@ultimate-js/hono",
    "@ultimate-js/router": "jsr:@ultimate-js/router",
    "@ultimate-js/react": "jsr:@ultimate-js/react",
    "hono": "jsr:@hono/hono",
    "react": "npm:react@19",
    "react-dom": "npm:react-dom@19",
    "react-dom/client": "npm:react-dom@19/client"
  },
  "compilerOptions": {
    "jsx": "react",
    "lib": ["dom", "dom.iterable", "deno.ns"]
  },
  "tasks": {
    "dev": "deno run -A jsr:@ultimate-js/cli dev",
    "build": "deno run -A jsr:@ultimate-js/cli build",
    "preview": "deno run -A jsr:@ultimate-js/cli preview"
  }
}
